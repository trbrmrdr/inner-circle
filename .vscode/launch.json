{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Inner Circle Server: debug",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/server",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx"
      ],
      "program": "${workspaceFolder}/server/src/server.ts",
      "env": {
        "ENV_FILE": "env/local.env"
      },
      "envFile": "${workspaceFolder}/server/env/local.env",
      "console": "integratedTerminal",
      "sourceMaps": true,
      "smartStep": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
