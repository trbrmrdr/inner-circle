{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Inner Circle Server: debug",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/server",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx",
        "src/server.ts"
      ],
      "envFile": "${workspaceFolder}/server/.env",
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
